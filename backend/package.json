{
  "name": "pizza-app-backend",
  "version": "1.0.0",
  "description": "Backend API for Pizza Ordering System with Express, MySQL, and JWT Authentication",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "db:sync": "node -e \"require('./src/config/db').sequelize.sync({ alter: true });\"",
    "db:reset": "node -e \"require('./src/config/db').sequelize.sync({ force: true });\""
  },
  "keywords": [
    "pizza",
    "ordering",
    "api",
    "express",
    "mysql",
    "sequelize",
    "jwt",
    "authentication"
  ],
  "author": "Pizza App Team",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
